# Database Configuration (Defaults for local XAMPP)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=grab_and_go

# Google OAuth Configuration (From Google Cloud Console)
# See: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=123456789-example.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-example_secret
# Leave redirect URI empty on Railway to use automatic detection
GOOGLE_REDIRECT_URI=http://localhost/Mini%20Project/auth/google-callback.php

# SMTP Email Configuration (For password resets)
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=abcd_efgh_ijkl_mnop
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME="Grab & Go"

# Project Base URL (Relative path)
BASE_URL=/Mini%20Project/

# Firebase Configuration (From Firebase Console)
FIREBASE_API_KEY=AIzaSy...your_key...
FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
FIREBASE_PROJECT_ID=your-app-id
FIREBASE_STORAGE_BUCKET=your-app.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef...

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_secret...
